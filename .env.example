# Pacely env vars
#
# Copy this file to .env.local for local dev. Vercel reads the same names
# from the project Environment Variables UI in production.

# --- Server-side (only readable inside api/*.ts) ---------------------------
# OpenAI key for the /api/llm proxy. NEVER prefix this with VITE_ — that
# would bundle it into the client JS.
OPENAI_API_KEY=sk-...

# --- Client-side (bundled into the SPA at build time) ---------------------
# Set to "true" to route all agent calls through the real OpenAI bundle.
# Any other value (or missing) uses the deterministic mock agents.
VITE_USE_LLM=false
